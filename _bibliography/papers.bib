@article{gaus2026confidence,
  abbr            = {ICRA Workshop},
  title           = {Confidence-Gated Robot Autonomy: When Does Uncertainty Actually Help?},
  author          = {Gaus, Johannes A. and Charaja, Jhon P. F. and Haeufle, Daniel},
  year            = {2026},
  arxiv           = {2605.18045},
  bibtex_show     = {true},
  preview         = {confidence-gate.png},
  selected        = {true},
  additional_info = {Benchmarks softmax scores, Monte Carlo dropout, and deep ensembles by the act or defer decisions they produce for wearable activity recognition. Once the base model is competent, estimator complexity matters less and the choice of gating threshold becomes the dominant factor.}
