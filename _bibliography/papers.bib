@article{gaus2026super,
  abbr            = {Preprint},
  title           = {SUPER: A Framework for Sensitivity-Based Uncertainty-Aware Performance and Risk Assessment in Visual Inertial Odometry},
  author          = {Gaus, Johannes A. and Häufle, Daniel and Baek, Woo-Jeong},
  year            = {2026},
  arxiv           = {2512.14189},
  bibtex_show     = {true},
  preview         = {super.png},
  additional_info = {Reads a risk signal straight out of the optimizer's own sensitivity structure, so it is backend agnostic and needs no extra sensors or retraining. SUPER forecasts trajectory degradation before it happens and triggers recovery for under 0.2 percent additional CPU cost. Currently under review.}
}

@article{gaus2026guard,
  abbr            = {IROS},
  title           = {GUARD: Toward a Compromise Between Traditional Control and Learning for Safe Robot Systems},
  author          = {Gaus, Johannes A. and Yoon, Junheon and Baek, Woo-Jeong and Choi, Seungwon and Park, Suhan and Park, Jaeheung},
  year            = {2026},
  arxiv           = {2509.23312},
  bibtex_show     = {true},
  preview         = {guard.png},
  additional_info = {Pairs transparent model-predictive control with uncertainty-aware perception so collision avoidance stays fast while the safety logic remains transparent. The framework keeps the sample efficiency of learning while leaving the safety-critical behavior easy to inspect. Under submission at IROS 2026.}
