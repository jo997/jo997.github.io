  author          = {Gaus, Johannes A. and Schneider, Loris and Shi, Yitian and Lee, Jongseok and Rayyes, Rania and Triebel, Rudolph},
  booktitle       = {IEEE International Conference on Robotics and Automation (ICRA)},
