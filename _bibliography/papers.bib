@article{gaus2026when,
  abbr            = {BioRob},
  title           = {When to Act: Calibrated Confidence for Reliable Human Intention Prediction in Assistive Robotics},
  author          = {Gaus, Johannes A. and Ilg, Winfried and Haeufle, Daniel},
  year            = {2026},
  arxiv           = {2601.04982},
  bibtex_show     = {true},
  preview         = {when-to-act.png},
  selected        = {true},
  additional_info = {Turns calibrated intention confidence into a verifiable ACT or HOLD safety rule for assistive devices. Post-hoc calibration shrinks the gap between reported confidence and true correctness by roughly an order of magnitude, so a single threshold can serve as an interpretable safety parameter. Submitted to IEEE RAS/EMBS BioRob.}
}

@inproceedings{gaus2026human,
